SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Dashboard → Project Settings → API Keys
# Backend: use "secret" key (sb_secret_...) or legacy "service_role" (eyJ...)
# Do NOT use sb_publishable_ here — that is for the React app only
SUPABASE_KEY=your_secret_or_service_role_key_here

# PDF indexing: light (offline chunks) | full (ML models) | auto
RAG_INDEX_MODE=light

# PDF / RAG pipeline (optional — HuggingFace for gated models)
# HF_TOKEN=
# HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Fal.ai — text2audio2video workflow (https://fal.ai)
FAL_KEY=your_fal_api_key_here
FAL_VOICE=Sarah
FAL_STABILITY=0.6
FAL_VIDEO_PROMPT=professional lecture speech
# Portrait image URL (jpg/png) — same as Fal playground "avatar" field
# Must be a public jpg/png URL Fal can download (upload in Fal playground → copy URL)
FAL_DEFAULT_AVATAR_URL=https://storage.googleapis.com/falserverless/example_inputs/kling_ai_avatar_input.jpg
# auto = try FAL_WORKFLOW, then public TTS+video if workflow not found
# workflow = only your Fal workflow | pipeline = ElevenLabs TTS + Kling avatar
FAL_MODE=auto
# Optional ISO code for custom workflow only (leave empty for auto-detect)
# FAL_LANGUAGE_CODE_ISO=
# Only if you own this workflow on the same Fal account as FAL_KEY:
# FAL_WORKFLOW=workflows/YOUR_USERNAME/text2audio2video

# PDF → lecture script (pick one)
SCRIPT_PROVIDER=grok
XAI_API_KEY=your_xai_api_key_from_console.x.ai
GROK_MODEL=grok-2-1212
GROK_TIMEOUT=180

# External RAG → TTS API (only if SCRIPT_PROVIDER=rag)
# Update when ngrok restarts — old URLs cause SSL/connection errors
RAG_TTS_API_URL=https://YOUR-SUBDOMAIN.ngrok-free.dev/api/rag-to-tts
RAG_TTS_NGROK_HEADER=true
RAG_TTS_TIMEOUT=120
# Set to false only if you get SSL errors on a trusted dev tunnel
# RAG_TTS_VERIFY_SSL=true
