# Python backend URL (FastAPI)
# Local dev: Vite proxy forwards /api -> http://127.0.0.1:8000
VITE_API_BASE_URL=/api

# Vercel Services (vercel.json): backend at /_/backend
# VITE_API_BASE_URL=/_/backend/api
#
# Vercel Dashboard → Settings → Environment Variables (Production + Preview):
#   SUPABASE_URL, SUPABASE_KEY, XAI_API_KEY, FAL_KEY, SCRIPT_PROVIDER=grok
# Project Framework must be "Services" (not plain Vite) when using experimentalServices.
