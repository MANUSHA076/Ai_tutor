{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite",
      "buildCommand": "npm run build",
      "outputDirectory": "dist"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend",
      "framework": "fastapi",
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/((?!_|api|assets|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
